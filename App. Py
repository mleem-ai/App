from flask import Flask, render_template
import json

app = Flask(__name__)

@app.route('/')
def index():
    with open('data/data.json', 'r', encoding='utf-8') as f:
        apartments = json.load(f)
    return render_template('index.html', apartments=apartments)

if __name__ == '__main__':
    app.run(debug=True)
