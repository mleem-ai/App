<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Планировки квартир</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
</head>
<body>

<h1>Планировки квартир</h1>

<div class="container">
    {% for apt in apartments %}
    <div class="card">
        <img src="{{ url_for('static', filename=apt['изображение']) }}" alt="">
        <h2>{{ apt['название'] }}</h2>
        <p><strong>Площадь:</strong> {{ apt['площадь'] }}</p>
        <p>{{ apt['описание'] }}</p>
    </div>
    {% endfor %}
</div>

</body>
</html>
