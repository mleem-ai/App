body {
    font-family: Arial;
    text-align: center;
    background: #f5f5f5;
}

nav a {
    margin: 10px;
    text-decoration: none;
    font-weight: bold;
    color: black;
}

nav a:hover {
    color: #0088cc;
}

button {
    padding: 10px 20px;
    background: #0088cc;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}
